# =============================================================================
# Model Configuration for AI Task Assistant
# Reference: https://github.com/panaversity/learn-agentic-ai/tree/main/01_ai_agents_first/05_model_configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Provider Selection
# -----------------------------------------------------------------------------
# Options: gemini, openai, anthropic, custom
MODEL_PROVIDER=gemini

# Use LiteLLM for model routing (supports 100+ models)
# Set to 'true' to enable LiteLLM, 'false' for direct provider SDK
USE_LITELLM=false

# -----------------------------------------------------------------------------
# Model Selection
# -----------------------------------------------------------------------------
# Generic model name (auto-resolved based on MODEL_PROVIDER)
MODEL_NAME=gemini-2.0-flash

# Provider-specific model overrides (optional)
GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

OPENAI_MODEL=gpt-4.1-mini
# OPENAI_MODEL=gpt-5.2

ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# -----------------------------------------------------------------------------
# API Keys (set only the one for your chosen provider)
# -----------------------------------------------------------------------------
# Gemini API Key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAWqzMP8cEe7FuGVPd5utWpWOn8IXpv9XI

# OpenAI API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Custom Provider API Key
CUSTOM_API_KEY=your-custom-api-key-here

# -----------------------------------------------------------------------------
# Model Configuration Settings
# -----------------------------------------------------------------------------
# Temperature: 0.0 (deterministic) to 1.0 (creative)
MODEL_TEMPERATURE=0.4

# Max tokens for response
MODEL_MAX_TOKENS=700

# Top P: nucleus sampling parameter
MODEL_TOP_P=0.9

# -----------------------------------------------------------------------------
# Custom Provider Configuration (if MODEL_PROVIDER=custom)
# -----------------------------------------------------------------------------
CUSTOM_BASE_URL=https://your-custom-llm-endpoint.com/v1

# -----------------------------------------------------------------------------
# Gemini-Specific Configuration (if using direct endpoint without LiteLLM)
# -----------------------------------------------------------------------------
# OpenAI-compatible Chat Completions API endpoint for Gemini
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# -----------------------------------------------------------------------------
# Rate Limiting (10 requests per minute per user)
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Backend API URL
# -----------------------------------------------------------------------------
BACKEND_API_URL=http://localhost:8000/api

# =============================================================================
# Example Configurations
# =============================================================================

# Example 1: Using Gemini with LiteLLM
# MODEL_PROVIDER=gemini
# USE_LITELLM=true
# MODEL_NAME=gemini-2.0-flash
# GEMINI_API_KEY=your-key-here

# Example 2: Using Gemini with direct endpoint (default)
# MODEL_PROVIDER=gemini
# USE_LITELLM=false
# MODEL_NAME=gemini-2.0-flash
# GEMINI_API_KEY=your-key-here
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Example 3: Using OpenAI GPT-4
# MODEL_PROVIDER=openai
# USE_LITELLM=false
# MODEL_NAME=gpt-4.1-mini
# OPENAI_API_KEY=your-key-here

# Example 4: Using Anthropic Claude via LiteLLM
# MODEL_PROVIDER=anthropic
# USE_LITELLM=true
# MODEL_NAME=claude-3-5-sonnet-20240620
# ANTHROPIC_API_KEY=your-key-here

# Example 5: Using Custom OpenAI-compatible endpoint
# MODEL_PROVIDER=custom
# MODEL_NAME=your-model-name
# CUSTOM_API_KEY=your-key-here
# CUSTOM_BASE_URL=https://your-endpoint.com/v1
