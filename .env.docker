# ════════════════════════════════════════════════════════
# DOCKER COMPOSE PRODUCTION ENVIRONMENT CONFIGURATION
# Production Mode (Neon PostgreSQL)
# ════════════════════════════════════════════════════════
# Copy this file to .env and configure for production
# 
# IMPORTANT: NEVER commit .env to git!
# Generate secrets: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# ════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────
# ENVIRONMENT (CRITICAL)
# ────────────────────────────────────────────────────────
ENVIRONMENT=production


# ════════════════════════════════════════════════════════
# SECURITY - JWT CONFIGURATION (REQUIRED)
# ════════════════════════════════════════════════════════
# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-32-CHARACTER-STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_AUDIENCE=multi-phase-todo-api
JWT_ISSUER=multi-phase-todo-backend


# ════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (REQUIRED)
# ════════════════════════════════════════════════════════
# Neon PostgreSQL (REQUIRED for production)
# Get your URL from: https://console.neon.tech
# Format: postgresql://user:password@host.region.provider.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host.region.provider.neon.tech/dbname?sslmode=require

# SQLite is NOT used in production (leave empty)
DATABASE_URL=


# ════════════════════════════════════════════════════════
# CACHE & RATE LIMITING (RECOMMENDED)
# ════════════════════════════════════════════════════════
# Use Redis Cloud, AWS ElastiCache, or similar
REDIS_URL=redis://redis:6379/0


# ════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (OPTIONAL)
# ════════════════════════════════════════════════════════
# For password reset, notifications, etc.
# SendGrid (recommended for production):
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USERNAME=apikey
EMAIL_PASSWORD=YOUR_SENDGRID_API_KEY
EMAIL_SENDER=noreply@yourdomain.com
SUPPORT_EMAIL=support@yourdomain.com


# ════════════════════════════════════════════════════════
# FRONTEND INTEGRATION (REQUIRED)
# ════════════════════════════════════════════════════════
# Your production domain
FRONTEND_BASE_URL=https://yourdomain.com
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_APP_NAME=Multi-Phase Todo
NEXT_PUBLIC_ENVIRONMENT=production


# ════════════════════════════════════════════════════════
# AI/LLM CONFIGURATION - QWEN VIA OPENROUTER (DEFAULT)
# ════════════════════════════════════════════════════════
# Get OpenRouter API key from: https://openrouter.ai/keys
MODEL_PROVIDER=openrouter
MODEL_NAME=qwen/qwen3-14b
USE_LITELLM=false
DEFAULT_MODEL=qwen/qwen3-14b
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://yourdomain.com
OPENROUTER_TITLE=Multi-Phase Todo App

# Model Settings
MODEL_TEMPERATURE=0.4
MODEL_MAX_TOKENS=700
MODEL_TOP_P=0.9

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Alternative: Google Gemini (if not using OpenRouter)
GEMINI_API_KEY=your-gemini-api-key-here


# ════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════════════════
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO


# ════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST
# ════════════════════════════════════════════════════════
# ✅ Set ENVIRONMENT=production
# ✅ Generate and set SECRET_KEY (32+ characters)
# ✅ Set NEON_DATABASE_URL from Neon console
# ✅ Set REDIS_URL for caching
# ✅ Update FRONTEND_BASE_URL to production domain
# ✅ Update NEXT_PUBLIC_API_BASE_URL to production API URL
# ✅ Set OPENROUTER_API_KEY for Qwen model
# ✅ Configure EMAIL settings
# ✅ Test with: docker compose --profile prod up -d
# ════════════════════════════════════════════════════════
